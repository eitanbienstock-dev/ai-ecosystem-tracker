     .from("companies")
     .update({
@@ -87,6 +92,8 @@ export async function promoteToInvested(companyId: string, formData: FormData) {
       entry_date: today,
       entry_price: entryPrice,
       shares_held: shares,
+      benchmark_ticker: BENCHMARK_TICKER,
